# Identifiants Snowflake — copie ce fichier en .env et remplis les valeurs.
# Ne committe JAMAIS le fichier .env (il est dans .gitignore).

# Identifiant du compte, ex: ABCDEFG-XY12345
# (Snowsight > en bas à gauche sur ton nom > Account > View account details > "Account Identifier")
SNOWFLAKE_ACCOUNT=

# Ton login Snowflake (champ "Login name" dans Account details — PAS ton email)
SNOWFLAKE_USER=

# Ton mot de passe Snowflake
SNOWFLAKE_PASSWORD=

# Le rôle (ACCOUNTADMIN par défaut sur un compte trial)
SNOWFLAKE_ROLE=ACCOUNTADMIN

# Correspondent à ce qu'on a créé dans Snowflake — ne pas changer
SNOWFLAKE_WAREHOUSE=NYC_TAXI_WH
SNOWFLAKE_DATABASE=NYC_TAXI_DB
SNOWFLAKE_SCHEMA=RAW
